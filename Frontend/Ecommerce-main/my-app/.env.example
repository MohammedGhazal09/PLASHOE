# Frontend Environment Template
# Copy to Frontend/Ecommerce-main/my-app/.env for local development.
# Only REACT_APP_* values are exposed to the browser by Create React App.
# Do not put backend secrets, Stripe secrets, JWT secrets, or MongoDB URIs here.
# Hosted staging/production builds must override example public values before npm run build; CRA embeds these values into the static bundle.

# API Configuration
# For hosted staging/production, set this to the matching deployed backend /api base URL before building.
REACT_APP_API_URL=http://localhost:5000/api

# Application Configuration
REACT_APP_NAME=PLASHOE
REACT_APP_DESCRIPTION=Sustainable Footwear for a Better Tomorrow
PUBLIC_URL=/

# External CDN/API URLs
REACT_APP_UNSPLASH_BASE_URL=https://images.unsplash.com

# Map Configuration
# This is a browser-visible public key. Restrict it by allowed HTTP origin when enabled, or leave unset to use fallback behavior.
REACT_APP_MAPTILER_API_KEY=<public-maptiler-browser-key>
REACT_APP_MAP_CENTER_LAT=24.7136
REACT_APP_MAP_CENTER_LNG=46.6753
REACT_APP_MAP_ZOOM=14

# Social Media Links
REACT_APP_FACEBOOK_URL=https://facebook.com/plashoe
REACT_APP_INSTAGRAM_URL=https://instagram.com/plashoe
REACT_APP_TWITTER_URL=https://twitter.com/plashoe
REACT_APP_PINTEREST_URL=https://pinterest.com/plashoe

# Company Info
REACT_APP_COMPANY_EMAIL=info@plashoe.com
REACT_APP_COMPANY_PHONE=+1-555-123-4567
REACT_APP_COMPANY_ADDRESS=123 Eco Street, Green City, CA 90210

# Feature Flags
REACT_APP_ENABLE_GUEST_CHECKOUT=true
REACT_APP_ENABLE_WISHLIST=false
REACT_APP_ENABLE_REVIEWS=false
