# Backend Environment Template
# Copy to Backend/.env for local development.
# Use deployment platform secrets/config for hosted environments.
# Do not commit real Backend/.env files.
# Placeholder values in this file are examples only and are rejected by hosted runtime validation until replaced outside source control.

# Database
MONGO_URI=<mongodb-connection-string>

# Authentication
JWT_SECRET=<32-plus-character-random-secret>
JWT_EXPIRE=1h

# Server
FRONTEND_URL=http://localhost:3000
PORT=5000

# Payments
# Keep PAYMENTS_ENABLED=false for local setup until real Stripe test/live secrets and return URLs are configured outside source control.
PAYMENTS_ENABLED=false
STRIPE_SECRET_KEY=<stripe-secret-key-from-dashboard>
STRIPE_WEBHOOK_SECRET=<stripe-webhook-signing-secret>
PAYMENT_SUCCESS_URL=http://localhost:3000/checkout/success
PAYMENT_CANCEL_URL=http://localhost:3000/checkout/cancel
