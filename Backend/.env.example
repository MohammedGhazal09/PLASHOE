# Backend Environment Template
# Copy to Backend/.env for local development.
# Use deployment platform secrets/config for hosted environments.
# Do not commit real Backend/.env files.
# Placeholder values in this file are examples only and are rejected by hosted runtime validation until replaced outside source control.

# Database
MONGO_URI=<mongodb-connection-string>
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000

# Authentication
JWT_SECRET=<32-plus-character-random-secret>
JWT_EXPIRE=1h

# Server
FRONTEND_URL=http://localhost:5173
PORT=5000

# Payments
# PAYMENTS_ENABLED=false forces the mock sandbox gateway. If this is true but the selected provider config is incomplete, the app also stays in mock mode.
PAYMENTS_ENABLED=false
PAYMENT_PROVIDER=mock
STRIPE_SECRET_KEY=<stripe-secret-key-from-dashboard>
STRIPE_WEBHOOK_SECRET=<stripe-webhook-signing-secret>
PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID=<paypal-sandbox-client-id>
PAYPAL_CLIENT_SECRET=<paypal-sandbox-client-secret>
PAYPAL_WEBHOOK_ID=<paypal-webhook-id>
PAYMENT_SUCCESS_URL=http://localhost:5173/checkout/success
PAYMENT_CANCEL_URL=http://localhost:5173/checkout/cancel
